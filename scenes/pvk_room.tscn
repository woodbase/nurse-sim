[gd_scene load_steps=5 format=3 uid="uid://pvk_room"]

[ext_resource type="Script" path="res://scenes/pvk_room.gd" id="1"]
[ext_resource type="PackedScene" path="res://scenes/Player.tscn" id="2"]

[sub_resource type="RectangleShape2D" id="1"]
size = Vector2(500, 20)

[node name="PVKRoom" type="Node"]
script = ExtResource("1")

[node name="Player" parent="." instance=ExtResource("2")]
position = Vector2(280, 220)

[node name="BoundaryFloor" type="StaticBody2D" parent="."]
position = Vector2(280, 320)

[node name="CollisionShape2D" type="CollisionShape2D" parent="BoundaryFloor"]
shape = SubResource("1")

[node name="UI" type="CanvasLayer" parent="."]

[node name="VBoxContainer" type="VBoxContainer" parent="UI"]
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2

[node name="Title" type="Label" parent="UI/VBoxContainer"]
text = "PVK Procedure – Tray Setup"
horizontal_alignment = 1

[node name="Instructions" type="Label" parent="UI/VBoxContainer"]
text = "All required items have been added to the tray automatically for this demo.\nPress Start Procedure to begin."
horizontal_alignment = 1
autowrap_mode = 3

[node name="MissingItemsLabel" type="Label" parent="UI/VBoxContainer"]
name = "MissingItemsLabel"
visible = false
modulate = Color(1, 0.2, 0.2, 1)
text = ""
horizontal_alignment = 1

[node name="StartProcedureButton" type="Button" parent="UI/VBoxContainer"]
text = "Start Procedure"

[connection signal="pressed" from="UI/VBoxContainer/StartProcedureButton" to="." method="_on_start_procedure_pressed"]
