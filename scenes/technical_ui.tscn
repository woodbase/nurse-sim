[gd_scene load_steps=2 format=3 uid="uid://technical_ui"]

[ext_resource type="Script" path="res://scenes/technical_ui.gd" id="1"]

[node name="TechnicalUI" type="Node"]
script = ExtResource("1")

[node name="UI" type="CanvasLayer" parent="."]

[node name="VBoxContainer" type="VBoxContainer" parent="UI"]
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2

[node name="Title" type="Label" parent="UI/VBoxContainer"]
text = "PVK Procedure – Step by Step"
horizontal_alignment = 1

[node name="HandDisinfectionButton" type="Button" parent="UI/VBoxContainer"]
text = "Hand Disinfection"

[node name="ApplyTourniquetButton" type="Button" parent="UI/VBoxContainer"]
text = "Apply Tourniquet"

[node name="SkinDisinfectionButton" type="Button" parent="UI/VBoxContainer"]
text = "Skin Disinfection"

[node name="InsertPVKButton" type="Button" parent="UI/VBoxContainer"]
text = "Insert PVK"

[node name="FlushPVKButton" type="Button" parent="UI/VBoxContainer"]
text = "Flush PVK"

[node name="FixateDressingButton" type="Button" parent="UI/VBoxContainer"]
text = "Fixate Dressing"

[node name="LabelPVKButton" type="Button" parent="UI/VBoxContainer"]
text = "Label PVK"

[connection signal="pressed" from="UI/VBoxContainer/HandDisinfectionButton" to="." method="_on_action_pressed" binds=["hand_disinfection"]]
[connection signal="pressed" from="UI/VBoxContainer/ApplyTourniquetButton" to="." method="_on_action_pressed" binds=["apply_tourniquet"]]
[connection signal="pressed" from="UI/VBoxContainer/SkinDisinfectionButton" to="." method="_on_action_pressed" binds=["skin_disinfection"]]
[connection signal="pressed" from="UI/VBoxContainer/InsertPVKButton" to="." method="_on_action_pressed" binds=["insert_pvk"]]
[connection signal="pressed" from="UI/VBoxContainer/FlushPVKButton" to="." method="_on_action_pressed" binds=["flush_pvk"]]
[connection signal="pressed" from="UI/VBoxContainer/FixateDressingButton" to="." method="_on_action_pressed" binds=["fixate_dressing"]]
[connection signal="pressed" from="UI/VBoxContainer/LabelPVKButton" to="." method="_on_action_pressed" binds=["label_pvk"]]
